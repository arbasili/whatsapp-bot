# ===========================================
# Clique e Fecha — Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha os valores.
# No Railway, configure cada uma em Variables.

# --- Servidor ---
# Porta do servidor (Railway define automaticamente; local usa 3000)
PORT=3000

# --- Banco de Dados (PostgreSQL) ---
# String de conexão completa do PostgreSQL (Railway fornece)
DATABASE_URL=
# Certificado da CA do provedor de Postgres (PEM), OPCIONAL — quando configurado,
# a conexão pública passa a validar o certificado de verdade (rejectUnauthorized: true)
# em vez do fallback inseguro. Sem isso, a conexão pública aceita qualquer certificado.
DB_CA_CERT=

# --- WhatsApp / Meta ---
# Token de verificação do webhook (você define; usado no handshake inicial)
VERIFY_TOKEN=
# App Secret do app da Meta (em developers.facebook.com > Configurações > Básico)
META_APP_SECRET=
# Token de acesso da WhatsApp Business API
WHATSAPP_TOKEN=
# ID do número de telefone na WhatsApp Business API
PHONE_NUMBER_ID=
# Versão da Graph API da Meta (opcional; padrão v21.0). Atualize quando a versão
# atual estiver perto de expirar — ver developers.facebook.com/docs/graph-api/changelog
META_GRAPH_API_VERSION=v21.0

# --- Identidade do cliente (deployment) ---
# CLIENT_ID: UUID do cliente deste deployment (obrigatório)
CLIENT_ID=
# Nome e email do cliente (usados no auto-registro em clients)
CLIENT_NAME=
CLIENT_EMAIL=

# --- Supabase (auth do painel) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Notificações internas ---
# MEU_NUMERO: WhatsApp do dono da operação (recebe avisos operacionais)
MEU_NUMERO=
# NUMERO_VENDEDOR: WhatsApp do comercial que trabalha os leads (recebe tarefas e
# alertas de lead quente). Se vazio, cai no MEU_NUMERO.
NUMERO_VENDEDOR=

# --- Google (Calendar + Sheets) ---
# JSON da service account do Google (cole o conteúdo completo do arquivo .json em uma linha)
GOOGLE_SERVICE_ACCOUNT_KEY=

# --- Claude / Anthropic ---
# Chave da API da Anthropic
ANTHROPIC_API_KEY=
# Modelo do Claude a usar (opcional; padrão claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6

# --- Groq (transcrição de áudio — OPCIONAL) ---
# Sem esta chave, o bot funciona mas não transcreve áudios
GROQ_API_KEY=

# --- Logs (OPCIONAL) ---
# Por padrão os logs incluem trechos das mensagens dos leads (útil na validação).
# Defina como false em produção para redigir o conteúdo (LGPD).
LOG_CONTEUDO=true

# --- Onboarding de novo cliente (multi-deploy) ---
# Origens do painel permitidas por CORS (separadas por vírgula). Um cliente novo
# com painel em outra URL PRECISA setar isto, senão o painel é bloqueado.
CORS_ORIGINS=https://painel-clique-fecha-production.up.railway.app,https://app.cliqueefecha.com.br
# Email do Google Workspace que a conta de serviço personifica pra acessar a
# agenda (normalmente igual ao CALENDAR_ID). Sem isto, o agendamento quebra.
GOOGLE_SUBJECT=comercial@cliqueefecha.com.br
# Calendar ID do cliente (também no config-cliente.js)
CALENDAR_ID=comercial@cliqueefecha.com.br
